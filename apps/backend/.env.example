# ─── Server ───
PORT=5001
NODE_ENV=development

# ─── Database ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexarats?schema=public

# ─── JWT ───
JWT_SECRET=change-me-in-production-use-a-256-bit-key
JWT_REFRESH_SECRET=change-me-too-use-a-different-256-bit-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── WhatsApp External Service (No API key needed) ───
WHATSAPP_API_URL=https://whatsapp-services-liart.vercel.app
WHATSAPP_SESSION_ID=nexarats

# ─── CORS ───
CORS_ORIGIN=http://localhost:5173

# ─── OTP ───
OTP_EXPIRY_MINUTES=5
