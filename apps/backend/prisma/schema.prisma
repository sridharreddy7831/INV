generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CASHIER
  STAFF
  ACCOUNTANT
  DELIVERY_AGENT
}

enum AccessLevel {
  MANAGE
  CRU
  READ
  NONE
}

enum ProductStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

enum TaxType {
  INCLUSIVE
  EXCLUSIVE
}

enum ReturnPolicy {
  RETURNABLE
  NOT_RETURNABLE
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  SPLIT
  BANK_TRANSFER
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
}

enum TransactionSource {
  ONLINE
  OFFLINE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum CustomerChannel {
  OFFLINE
  ONLINE
  BOTH
}

enum PurchaseStatus {
  PAID
  UNPAID
  PARTIAL
}

// ─────────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?  @unique
  password    String?
  role        UserRole @default(STAFF)
  permissions Json     @default("{}")
  isActive    Boolean  @default(true)
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
  auditLogs    AuditLog[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model OtpRecord {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, otp])
  @@map("otp_records")
}

model Product {
  id                 String        @id @default(cuid())
  name               String
  sku                String        @unique
  category           String
  price              Decimal       @db.Decimal(12, 2)
  purchasePrice      Decimal       @db.Decimal(12, 2)
  mrp                Decimal       @db.Decimal(12, 2) @default(0)
  discountPercentage Decimal       @db.Decimal(5, 2)  @default(0)
  stock              Int           @default(0)
  minStock           Int           @default(0)
  gstRate            Decimal       @db.Decimal(5, 2)  @default(18)
  hsnCode            String?
  unit               String        @default("Pieces")
  status             ProductStatus @default(IN_STOCK)
  taxType            TaxType       @default(INCLUSIVE)
  returns            ReturnPolicy  @default(RETURNABLE)
  image              String?
  description        String?
  expiryDate         DateTime?
  deletedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactionItems TransactionItem[]
  wishlistItems    Wishlist[]

  @@index([sku])
  @@index([category])
  @@index([status])
  @@index([name])
  @@map("products")
}

model Customer {
  id              String          @id @default(cuid())
  name            String
  email           String?
  phone           String          @unique
  password        String?
  totalPaid       Decimal         @db.Decimal(12, 2) @default(0)
  pending         Decimal         @db.Decimal(12, 2) @default(0)
  status          PaymentStatus   @default(PAID)
  lastTransaction DateTime?
  totalInvoices   Int             @default(0)
  address         String?
  channel         CustomerChannel @default(OFFLINE)
  totalOrders     Int             @default(0)
  totalSpent      Decimal         @db.Decimal(12, 2) @default(0)
  lastLogin       DateTime?
  isActive        Boolean         @default(true)
  deletedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
  addresses    Address[]
  wishlist     Wishlist[]
  orders       Order[]

  @@index([phone])
  @@index([email])
  @@index([channel])
  @@map("customers")
}

model Address {
  id         String  @id @default(cuid())
  customerId String
  label      String  @default("Home")
  name       String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  isDefault  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("addresses")
}

model Wishlist {
  id         String @id @default(cuid())
  customerId String
  productId  String
  addedAt    DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@map("wishlists")
}

model Vendor {
  id              String    @id @default(cuid())
  name            String
  businessName    String
  gstNumber       String?
  phone           String    @unique
  email           String?
  totalPaid       Decimal   @db.Decimal(12, 2) @default(0)
  pendingAmount   Decimal   @db.Decimal(12, 2) @default(0)
  lastTransaction DateTime?
  totalInvoices   Int       @default(0)
  image           String?
  deletedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases Purchase[]

  @@index([phone])
  @@index([gstNumber])
  @@map("vendors")
}

model Transaction {
  id             String            @id @default(cuid())
  customerId     String?
  userId         String?
  total          Decimal           @db.Decimal(12, 2)
  gstAmount      Decimal           @db.Decimal(12, 2) @default(0)
  method         PaymentMethod     @default(CASH)
  status         PaymentStatus     @default(PAID)
  source         TransactionSource @default(OFFLINE)
  orderStatus    OrderStatus?
  paidAmount     Decimal           @db.Decimal(12, 2) @default(0)
  assignedStaff  String?
  deliveryStatus String?
  date           DateTime          @default(now())
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  items    TransactionItem[]

  @@index([customerId])
  @@index([source])
  @@index([status])
  @@index([date])
  @@map("transactions")
}

model TransactionItem {
  id            String  @id @default(cuid())
  transactionId String
  productId     String
  name          String
  quantity      Int
  price         Decimal @db.Decimal(12, 2)
  gst           Decimal @db.Decimal(12, 2) @default(0)

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])

  @@index([transactionId])
  @@map("transaction_items")
}

model Purchase {
  id       String         @id @default(cuid())
  vendorId String
  amount   Decimal        @db.Decimal(12, 2)
  date     DateTime       @default(now())
  status   PurchaseStatus @default(UNPAID)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([status])
  @@map("purchases")
}

model Order {
  id          String      @id @default(cuid())
  customerId  String
  total       Decimal     @db.Decimal(12, 2)
  status      OrderStatus @default(PENDING)
  items       Json        @default("[]")
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}
